# =============================================
# Shivam's Workspace — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB — replace with your Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shivam_workspace?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
